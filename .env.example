# Backend .env — copy to .env and fill. Used by server and /api/config/public.

# Database (required)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=affiliate_tracking

# JWT
JWT_SECRET=your_jwt_secret_here

# Admin
ADMIN_EMAIL=admin@example.com

# Google OAuth (optional — leave empty to disable "Continue with Google" on login)
# Frontend gets this via GET /api/config/public. Use either variable:
GOOGLE_CLIENT_ID_PUBLIC=your_client_id.apps.googleusercontent.com
# Or (same value):
# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_client_secret

# SendPulse SMTP (for email verification)
SENDPULSE_SMTP_HOST=smtp-pulse.com
SENDPULSE_SMTP_PORT=587
SENDPULSE_SMTP_USER=your_sendpulse_login
SENDPULSE_SMTP_PASS=your_sendpulse_smtp_password
EMAIL_FROM_ADDRESS=lehko@lehko.space
EMAIL_FROM_NAME=Lehko

# Frontend base URL (for verification link in emails)
FRONTEND_URL=https://lehko.space

PORT=3000
